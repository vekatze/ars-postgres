{
  target {
    test {
      main "test.nt",
      build-option [
        "$(pkg-config libpq --libs --cflags)",
        // (AddressSanitizer might report memory leaks in libpq on macOS)
        "-fsanitize=address",
      ],
    },
  },
  zen {
    build-option [
      "$(pkg-config libpq --libs --cflags)",
    ],
  },
  foreign {
    input [
      "source/foreign.c",
    ],
    output [
      "foreign.o",
    ],
    script [
      "{{clang}} $(pkg-config libpq --libs --cflags) -c -flto=thin -O2 source/foreign.c -o {{foreign}}/foreign.o",
    ],
  },
  text-file {
    reset "source/sql/reset.sql",
    insert-author "source/sql/author/insert.sql",
    select-author "source/sql/author/select.sql",
  },
  dependency {
    core {
      digest "QKO_3GsvSZQcb45d1pwGPt2LGOXJAPOuXFaFN4tvNc8",
      mirror [
        "https://github.com/vekatze/neut-core/raw/main/archive/0-54-2.tar.zst",
      ],
      enable-preset true,
    },
    time {
      digest "RGuawX7OX2iBkb7ex0t49UduauWo_9so319YQIuYots",
      mirror [
        "https://github.com/vekatze/time-nt/raw/main/archive/0-4-50.tar.zst",
      ],
    },
  },
}
