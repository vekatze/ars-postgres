{
  target {
    test {
      main "test.nt",
      build-option [
        "$(pkg-config libpq --libs --cflags)",
        // (AddressSanitizer might report memory leaks in libpq on macOS)
        "-fsanitize=address",
      ],
    },
  },
  zen {
    build-option [
      "$(pkg-config libpq --libs --cflags)",
    ],
  },
  foreign {
    input [
      "source/foreign.c",
    ],
    output [
      "foreign.o",
    ],
    script [
      "{{clang}} $(pkg-config libpq --libs --cflags) -c -flto=thin -O2 source/foreign.c -o {{foreign}}/foreign.o",
    ],
  },
  text-file {
    reset "source/sql/reset.sql",
    insert-author "source/sql/author/insert.sql",
    select-author "source/sql/author/select.sql",
  },
  dependency {
    core {
      digest "yNWbpR6FH89l8vrvc2fh4PMZYlLEGtCzBHxT8aZQS5o",
      mirror [
        "https://github.com/vekatze/neut-core/raw/main/archive/0-54-9.tar.zst",
      ],
      enable-preset true,
    },
    time {
      digest "z9BK5qI3S5hE_xEavZ0wN9rboOg9uEPY8brRr_uFucc",
      mirror [
        "https://github.com/vekatze/time-nt/raw/main/archive/0-4-58.tar.zst",
      ],
    },
  },
}
